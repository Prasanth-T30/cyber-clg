# FusionGuardNet – Backend Environment Variables
# Copy this file to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=FusionGuardNet
DEBUG=True

# ── InstantDB ────────────────────────────────────────────────────────────────
INSTANTDB_APP_ID=your-instantdb-app-id-here
INSTANTDB_ADMIN_TOKEN=your-instantdb-admin-token-here

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-in-production

# ── Sniffer ──────────────────────────────────────────────────────────────────
# Set to False and specify SNIFFER_INTERFACE for live packet capture
SNIFFER_SIMULATION_MODE=True
SNIFFER_INTERFACE=eth0
